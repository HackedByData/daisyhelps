# Anthropic — for Claude (Haiku text turns, Sonnet vision turns)
ANTHROPIC_API_KEY=

# Groq — for Whisper Large v3 Turbo STT
GROQ_API_KEY=

# ElevenLabs — for streaming TTS
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID_EN=
ELEVENLABS_VOICE_ID_ES=

# Cloudflare — DNS token for daisyhelps.com zone (Zone:Read + DNS:Edit, scoped to daisyhelps.com)
CLOUDFLARE_API_TOKEN=

# Render — API key for managing the deploy (generate at dashboard.render.com/u/settings#api-keys)
RENDER_API_KEY=

# Logging
LOG_LEVEL=INFO
